<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Maa Gayatri Enterprises</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600&display=swap" rel="stylesheet">

<style>
:root{
--primary:#0d6efd;
--bg:#f4f6fb;
--card:#fff;
--text:#222;
}
.dark{
--bg:#121212;
--card:#1e1e1e;
--text:#fff;
}
body{
margin:0;font-family:'Poppins',sans-serif;
background:var(--bg);color:var(--text);
}
header{
position:sticky;top:0;
background:linear-gradient(45deg,#0d6efd,#00c6ff);
color:#fff;padding:15px;text-align:center;
}
.search{display:flex;gap:5px;margin-top:10px}
.search input{
flex:1;padding:10px;border:none;border-radius:8px;
}
.toggle{
padding:10px;border:none;border-radius:8px;cursor:pointer;
}
.grid{
display:grid;
grid-template-columns:repeat(auto-fill,minmax(160px,1fr));
gap:12px;padding:10px;
}
.card{
background:var(--card);
padding:10px;border-radius:12px;
box-shadow:0 4px 10px rgba(0,0,0,.1);
}
.card img{
width:100%;height:120px;
object-fit:cover;border-radius:8px;
}
.price{color:#28a745;font-weight:bold}
button{
border:none;padding:8px;border-radius:6px;
cursor:pointer;
}
.add{background:#28a745;color:#fff;width:100%}
.cart-btn{
position:fixed;bottom:20px;right:20px;
background:#ff5722;color:#fff;
padding:15px;border-radius:50%;
}
.cart{
position:fixed;top:0;right:-100%;
width:100%;height:100%;
background:var(--card);
transition:.3s;padding:15px;
overflow:auto;
}
.cart.active{right:0}
.cart-item{margin-bottom:10px;border-bottom:1px solid #ddd}
.total{font-weight:bold;margin-top:10px}
input,textarea{
width:100%;padding:10px;margin:5px 0;
border-radius:6px;border:1px solid #ccc;
}
.place{
background:var(--primary);color:#fff;width:100%;
}
.whatsapp{
position:fixed;bottom:20px;left:20px;
background:#25D366;color:#fff;
padding:15px;border-radius:50%;
text-decoration:none;
}
</style>
</head>

<body>

<header>
<h2>Maa Gayatri Enterprises</h2>
<small>Order Online • Pay Offline
